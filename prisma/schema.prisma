generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH MODELS (NextAuth v5)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// APP MODELS
// ============================================================

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password             String?
  fullName             String?
  dateOfBirth          DateTime?
  biologicalSex        String?
  isPro                Boolean   @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  accounts Account[]
  sessions Session[]
  reports  Report[]
  profiles Profile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id            String    @id @default(cuid())
  name          String
  dateOfBirth   DateTime?
  biologicalSex String?
  relationship  String?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports       Report[]

  createdAt DateTime @default(now())

  @@index([userId])
}

model Report {
  id          String    @id @default(cuid())
  source      String
  fileUrl     String?
  fileName    String?
  labProvider String?
  collectedAt DateTime?
  uploadedAt  DateTime  @default(now())
  status      String
  summary     String?   @db.Text
  flagCount   Int       @default(0)
  urgentFlag  Boolean   @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  markers   Marker[]
  questions Question[]

  @@index([userId])
  @@index([profileId])
}

model Marker {
  id             String  @id @default(cuid())
  name           String
  code           String?
  value          Float
  unit           String
  referenceMin   Float?
  referenceMax   Float?
  status         String
  explanation    String  @db.Text
  whatItMeasures String? @db.Text
  confidence     Float

  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([reportId])
}

model Question {
  id        String  @id @default(cuid())
  text      String  @db.Text
  priority  Int
  relatedTo String?

  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model MarkerCatalog {
  id             String   @id @default(cuid())
  canonicalName  String   @unique
  aliases        String[]
  category       String
  whatItMeasures String   @db.Text
  normalRangeMin Float?
  normalRangeMax Float?
  unit           String
  urgentHigh     Float?
  urgentLow      Float?
}
