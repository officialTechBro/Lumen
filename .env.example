# Neon PostgreSQL — dev branch connection string
# IMPORTANT: Use the DIRECT connection string (no "-pooler" in the hostname).
# The pooler URL only supports HTTP/WebSocket; Prisma migrations and the pg driver need raw TCP.
# Find this in your Neon dashboard → Connection Details → toggle off "Connection pooling"
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
